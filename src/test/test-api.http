  "publisherId": "N1373616",
  "title": "React Refresher (Past)",
  "type": "Workshop",
  "date": "2025-01-10",
  "time": "14:00",
  "duration": 120,
  "location": "NG1 4FQ",
  "venue": "Computer Lab A, City Campus",
  "cost": 0.0,
  "maxParticipants": 20,
  "description": "Past workshop. Use for rating tests."
}

